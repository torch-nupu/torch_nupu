{
  "version": 8,
  "configurePresets": [
    {
      "name": "osx",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/torch_nupu",
        "CMAKE_EXPORT_COMPILE_COMMANDS": true,
        "CMAKE_C_COMPILER": "/usr/bin/clang",
        "CMAKE_CXX_COMPILER": "/usr/bin/clang++",
        "CMAKE_LINKER_TYPE": "LLD",
        "CMAKE_INSTALL_RPATH_USE_LINK_PATH": true
      }
    },
    {
      "name": "demo",
      "inherits": "osx",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "/repos/_work/llvm-dpcpp-sycl-web/build/bin/clang",
        "CMAKE_CXX_COMPILER": "/repos/_work/llvm-dpcpp-sycl-web/build/bin/clang++",
        "SYCL_ROOT": "/repos/_work/llvm-dpcpp-sycl-web/build"
      }
    }
  ]
}
